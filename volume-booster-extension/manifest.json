{
  "manifest_version": 3,
  "name": "Volume Booster",
  "version": "1.0",
  "description": "Amplify the volume of media playing in your browser.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Adjust Volume"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}