{
  "manifest_version": 3,
  "name": "Volume Booster",
  "version": "1.0",
  "description": "Amplify the volume of media playing in your browser.",
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "offscreen",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "volume-up": {
      "suggested_key": {
        "default": "Alt+Shift+Up"
      },
      "description": "Increase volume by 10%"
    },
    "volume-down": {
      "suggested_key": {
        "default": "Alt+Shift+Down"
      },
      "description": "Decrease volume by 10%"
    },
    "volume-preset": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Jump to preset volume"
    },
    "volume-reset": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Turn off / Reset volume"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Adjust Volume"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}